# Copy to .env (gitignored) for local dev, and set the same vars in Vercel's project env.

# --- Sanity CMS (set after creating the project) ---
PUBLIC_SANITY_PROJECT_ID=
PUBLIC_SANITY_DATASET=production
# Secret — only needed for draft/preview reads. Set in Vercel env, never commit.
SANITY_READ_TOKEN=

# --- Forms ---
# Web3Forms access key for the contact form (https://web3forms.com — tie to connect@bigredoak.com)
PUBLIC_WEB3FORMS_KEY=
# Mailchimp embedded-form action URL (Mailchimp → Audience → Signup forms → Embedded form)
PUBLIC_MAILCHIMP_ACTION=

# --- Hosting ---
# Final public URL on Vercel (e.g. https://bigredoak.com). Used for canonical/OG/sitemap.
SITE_URL=
