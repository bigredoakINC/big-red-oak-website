# Copy to .env (gitignored) for local dev, and set the same vars in the host's env.

# --- Forms ---
# Web3Forms access key for the contact form (https://web3forms.com — tie to connect@bigredoak.com)
PUBLIC_WEB3FORMS_KEY=
# Mailchimp embedded-form action URL (Mailchimp → Audience → Signup forms → Embedded form)
PUBLIC_MAILCHIMP_ACTION=

# --- Hosting ---
# Final public URL once a host is chosen (e.g. https://bigredoak.com). Used for canonical/OG/sitemap.
SITE_URL=

# NOTE: Content is managed in-repo (src/data/content.ts + src/content/*) and edited by
# agents — no separate CMS account (Sanity was dropped; not requested in the PRD).
