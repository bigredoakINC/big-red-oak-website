# Copy to .env (gitignored) for local dev, and set the same as repo variables/secrets
# in GitHub for the Firebase deploy workflow.

# --- Forms ---
# Web3Forms access key for the contact form (https://web3forms.com — tie to connect@bigredoak.com)
PUBLIC_WEB3FORMS_KEY=
# Mailchimp embedded-form action URL (Mailchimp → Audience → Signup forms → Embedded form)
PUBLIC_MAILCHIMP_ACTION=

# --- Hosting (Firebase) ---
# Production build target. The Firebase deploy workflow sets DEPLOY_TARGET=firebase.
# DEPLOY_TARGET=firebase
# Final public URL (e.g. https://bigredoak.com). Used for canonical/OG/sitemap.
SITE_URL=

# Firebase deploy (set in GitHub as repo variables/secrets, not committed):
#   variable  FIREBASE_ENABLED=true
#   variable  FIREBASE_PROJECT_ID=<firebase-project-id>
#   secret    FIREBASE_SERVICE_ACCOUNT=<service-account-json>

# NOTE: Content is managed in-repo (src/data/content.ts + src/content/*) and edited by
# agents — no separate CMS account.
