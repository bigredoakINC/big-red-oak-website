---
import { nav, site, memberships } from '../data/content';
import { withBase } from '../lib/util';
---
<footer class="border-t border-line bg-ink text-white/80">
  <div class="mx-auto grid max-w-6xl gap-10 px-5 py-14 md:grid-cols-3">
    <div>
      <p class="font-serif text-lg font-semibold text-white">Big Red Oak</p>
      <p class="mt-3 max-w-xs text-sm text-white/60">{site.tagline}</p>
      <a href={`mailto:${site.email}`} class="mt-4 inline-block text-sm text-white hover:underline">{site.email}</a>
    </div>

    <div>
      <p class="text-xs font-semibold uppercase tracking-wider text-white/50">Navigate</p>
      <ul class="mt-4 space-y-2">
        {nav.map((item) => (
          <li><a href={withBase(item.href)} class="text-sm text-white/70 hover:text-white">{item.label}</a></li>
        ))}
      </ul>
    </div>

    <div>
      <p class="text-xs font-semibold uppercase tracking-wider text-white/50">Memberships</p>
      <p class="mt-4 text-sm text-white/70">{memberships.join(' · ')}</p>
      <a href={site.linkedin} target="_blank" rel="noopener noreferrer" class="mt-4 inline-block text-sm text-white hover:underline">LinkedIn →</a>
    </div>
  </div>
  <div class="border-t border-white/10">
    <div class="mx-auto flex max-w-6xl flex-col items-center justify-between gap-2 px-5 py-5 text-xs text-white/50 sm:flex-row">
      <span>© {new Date().getFullYear()} Big Red Oak. All rights reserved.</span>
      <span>Clean energy · Nuclear · Energy transition</span>
    </div>
  </div>
</footer>
