---
interface Props {
  eyebrow?: string;
  title: string;
  sub?: string;
  center?: boolean;
  level?: 1 | 2;
}
const { eyebrow, title, sub, center = false, level = 2 } = Astro.props;
const Tag = level === 1 ? 'h1' : 'h2';
---
<div class={center ? 'mx-auto max-w-2xl text-center' : 'max-w-2xl'}>
  {eyebrow && <p class="mb-2 text-xs font-semibold uppercase tracking-[0.15em] text-accent">{eyebrow}</p>}
  <Tag class="font-serif text-3xl font-semibold md:text-4xl">{title}</Tag>
  {sub && <p class="mt-4 text-lg text-muted">{sub}</p>}
</div>
