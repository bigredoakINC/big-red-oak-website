---
import { withBase } from '../lib/util';

interface Props {
  href: string;
  title: string;
  excerpt: string;
  meta?: string;
  tag?: string;
}
const { href, title, excerpt, meta, tag } = Astro.props;
---
<a href={withBase(href)} class="group flex flex-col rounded-[var(--radius-card)] border border-line bg-white p-6 transition-shadow hover:shadow-md">
  {tag && <span class="mb-3 inline-block w-max rounded-full bg-accent-soft px-3 py-1 text-xs font-semibold text-accent-ink">{tag}</span>}
  <h3 class="text-lg font-semibold text-ink group-hover:text-accent">{title}</h3>
  <p class="mt-2 flex-1 text-sm leading-relaxed text-muted">{excerpt}</p>
  {meta && <p class="mt-4 text-xs text-muted/80">{meta}</p>}
  <span class="mt-3 text-sm font-medium text-accent">Read more →</span>
</a>
