---
import { nav, site } from '../data/content';
import { withBase } from '../lib/util';
import Button from './Button.astro';

const current = Astro.url.pathname.replace(/\/$/, '');
const isActive = (href: string) => {
  const target = withBase(href).replace(/\/$/, '');
  return current === target || (href !== '/' && current.startsWith(target));
};
---
<header class="sticky top-0 z-50 border-b border-line bg-white/90 backdrop-blur">
  <div class="mx-auto flex h-16 max-w-6xl items-center justify-between px-5">
    <a href={withBase('/')} aria-label="Big Red Oak — home" class="font-serif text-lg font-semibold text-ink">
      Big Red Oak
    </a>

    <nav aria-label="Primary" class="hidden items-center gap-7 md:flex">
      {nav.map((item) => (
        <a
          href={withBase(item.href)}
          aria-current={isActive(item.href) ? 'page' : undefined}
          class={`text-sm font-medium transition-colors ${
            isActive(item.href) ? 'text-accent' : 'text-body hover:text-ink'
          }`}
        >
          {item.label}
        </a>
      ))}
    </nav>

    <div class="hidden md:block">
      <Button href={site.bookingUrl} external class="px-5 py-2.5 text-xs">Book a Consultation</Button>
    </div>

    <!-- Mobile menu (no-JS friendly via <details>) -->
    <details class="relative md:hidden">
      <summary class="flex h-10 w-10 cursor-pointer list-none items-center justify-center rounded-lg border border-line" aria-label="Open menu">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="text-ink" aria-hidden="true">
          <line x1="3" y1="6" x2="21" y2="6" /><line x1="3" y1="12" x2="21" y2="12" /><line x1="3" y1="18" x2="21" y2="18" />
        </svg>
      </summary>
      <div class="absolute right-0 mt-2 w-56 rounded-xl border border-line bg-white p-2 shadow-lg">
        {nav.map((item) => (
          <a href={withBase(item.href)} class="block rounded-lg px-3 py-2 text-sm font-medium text-body hover:bg-mist">
            {item.label}
          </a>
        ))}
        <a href={site.bookingUrl} target="_blank" rel="noopener noreferrer" class="mt-1 block rounded-lg bg-accent px-3 py-2 text-center text-sm font-semibold text-white">
          Book a Consultation
        </a>
      </div>
    </details>
  </div>
</header>
