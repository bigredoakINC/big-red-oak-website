---
import { getCollection, type CollectionEntry } from 'astro:content';
import Base from '../../layouts/Base.astro';
import Section from '../../components/Section.astro';
import { withBase } from '../../lib/util';

export async function getStaticPaths() {
  const cases = await getCollection('work', ({ data }) => !data.draft);
  return cases.map((entry) => ({ params: { slug: entry.slug }, props: { entry } }));
}

type Props = { entry: CollectionEntry<'work'> };
const { entry } = Astro.props;
const { Content } = await entry.render();
---
<Base title={entry.data.title} description={entry.data.summary}>
  <Section>
    <a href={withBase('/our-work')} class="text-sm font-medium text-accent">← Our Work</a>
    <article class="mx-auto mt-6 max-w-3xl">
      <p class="text-xs font-semibold uppercase tracking-wider text-accent">{entry.data.client}</p>
      <h1 class="mt-3 font-serif text-4xl font-semibold">{entry.data.title}</h1>
      <p class="mt-4 text-lg text-muted">{entry.data.summary}</p>

      {entry.data.metrics.length > 0 && (
        <div class="mt-8 grid grid-cols-2 gap-4 sm:grid-cols-3">
          {entry.data.metrics.map((m) => (
            <div class="rounded-[var(--radius-card)] border border-line bg-mist p-5">
              <div class="font-serif text-2xl font-semibold text-ink">{m.value}</div>
              <div class="mt-1 text-xs uppercase tracking-wider text-muted">{m.label}</div>
            </div>
          ))}
        </div>
      )}

      <div class="prose-bro mt-10">
        <Content />
      </div>
    </article>
  </Section>
</Base>

<style is:global>
  .prose-bro { color: var(--color-body); }
  .prose-bro h2 { margin: 2rem 0 0.75rem; font-size: 1.6rem; font-weight: 600; }
  .prose-bro p { margin: 1rem 0; line-height: 1.8; }
</style>
