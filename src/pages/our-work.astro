---
import { getCollection } from 'astro:content';
import Base from '../layouts/Base.astro';
import Hero from '../components/Hero.astro';
import Section from '../components/Section.astro';
import SectionHeading from '../components/SectionHeading.astro';
import Card from '../components/Card.astro';
import PostCard from '../components/PostCard.astro';
import { work } from '../data/content';

const cases = (await getCollection('work', ({ data }) => !data.draft))
  .sort((a, b) => b.data.publishedAt.valueOf() - a.data.publishedAt.valueOf());
---
<Base title="Our Work" description={work.intro.body}>
  <Hero eyebrow="Our work" title={work.intro.title} sub={work.intro.body} showCta={false} />

  <Section>
    <SectionHeading eyebrow="Capabilities" title="Six ways we help" />
    <div class="mt-10 grid gap-5 sm:grid-cols-2 lg:grid-cols-3">
      {work.capabilities.map((c) => (
        <Card title={c.title}>{c.body}</Card>
      ))}
    </div>
  </Section>

  <Section tint>
    <SectionHeading eyebrow="Case studies" title="Selected work" sub="Featured case studies. Full project grid to be expanded as BRO confirms content." />
    <div class="mt-10 grid gap-5 sm:grid-cols-2 lg:grid-cols-3">
      {cases.map((c) => (
        <PostCard
          href={`/work/${c.slug}`}
          title={c.data.title}
          excerpt={c.data.summary}
          tag={c.data.client}
          meta={c.data.publishedAt.toLocaleDateString('en-CA', { year: 'numeric', month: 'short' })}
        />
      ))}
    </div>
  </Section>
</Base>
