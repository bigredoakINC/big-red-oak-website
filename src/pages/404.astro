---
import Base from '../layouts/Base.astro';
import Button from '../components/Button.astro';
---
<Base title="Page not found" description="The page you’re looking for doesn’t exist.">
  <section class="mx-auto max-w-2xl px-5 py-28 text-center">
    <p class="text-xs font-semibold uppercase tracking-[0.15em] text-accent">Error 404</p>
    <h1 class="mt-3 font-serif text-4xl font-semibold md:text-5xl">Page not found</h1>
    <p class="mt-4 text-lg text-muted">The page you’re looking for doesn’t exist or has moved.</p>
    <div class="mt-8 flex justify-center gap-3">
      <Button href="/">Back to home</Button>
      <Button href="/contact" variant="ghost">Contact us</Button>
    </div>
  </section>
</Base>
