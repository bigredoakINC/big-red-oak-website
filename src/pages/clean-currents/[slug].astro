---
import { getCollection, type CollectionEntry } from 'astro:content';
import Base from '../../layouts/Base.astro';
import Section from '../../components/Section.astro';
import { withBase } from '../../lib/util';

export async function getStaticPaths() {
  const posts = await getCollection('posts', ({ data }) => !data.draft);
  return posts.map((post) => ({ params: { slug: post.slug }, props: { post } }));
}

type Props = { post: CollectionEntry<'posts'> };
const { post } = Astro.props;
const { Content } = await post.render();
const fmt = (d: Date) => d.toLocaleDateString('en-CA', { year: 'numeric', month: 'long', day: 'numeric' });
---
<Base title={post.data.title} description={post.data.excerpt}>
  <Section>
    <a href={withBase('/clean-currents')} class="text-sm font-medium text-accent">← Clean Currents</a>
    <article class="mx-auto mt-6 max-w-3xl">
      <p class="text-xs font-semibold uppercase tracking-wider text-muted">{fmt(post.data.publishedAt)} · {post.data.author}</p>
      <h1 class="mt-3 font-serif text-4xl font-semibold">{post.data.title}</h1>
      <p class="mt-4 text-lg text-muted">{post.data.excerpt}</p>
      <div class="prose-bro mt-10">
        <Content />
      </div>
    </article>
  </Section>
</Base>

<style is:global>
  .prose-bro { color: var(--color-body); }
  .prose-bro h2 { margin: 2rem 0 0.75rem; font-size: 1.6rem; font-weight: 600; }
  .prose-bro h3 { margin: 1.5rem 0 0.5rem; font-size: 1.25rem; font-weight: 600; }
  .prose-bro p { margin: 1rem 0; line-height: 1.8; }
  .prose-bro ul { margin: 1rem 0; padding-left: 1.25rem; list-style: disc; }
  .prose-bro li { margin: 0.35rem 0; }
  .prose-bro a { color: var(--color-accent); text-decoration: underline; }
</style>
